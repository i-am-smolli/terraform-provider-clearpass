                },
                "description": {
                    "type": "string",
                    "description": "Description of the extension"
                },
                "icon_href": {
                    "type": "string",
                    "description": "URL for the extension\u2019s icon"
                },
                "about_href": {
                    "type": "string",
                    "description": "URL for the extension\u2019s documentation"
                },
                "hostname": {
                    "type": "string",
                    "description": "Hostname assigned to the extension"
                },
                "network_ports": {
                    "type": "array",
                    "description": "List of network ports provided by the extension",
                    "items": {
                        "$ref": "ExtensionInstanceNetworkPort"
                    }
                },
                "extension_hrefs": {
                    "type": "array",
                    "description": "List of URLs provided by the extension",
                    "items": {
                        "$ref": "ExtensionInstanceHref"
                    }
                },
                "files": {
                    "type": "object",
                    "description": "Map of extension file IDs to local content items, with \u2018public:\u2019 or \u2018private:\u2019 prefix"
                },
                "file_descriptions": {
                    "type": "object",
                    "description": "Contains a description of each extension file ID"
                },
                "internal_ip_address": {
                    "type": "string",
